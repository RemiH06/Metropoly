# ── Assets generados — excluir TODO excepto muestras ──
# Nota: para poder incluir excepciones, NO se excluye el directorio
# sino los contenidos con patrones.

# Casillas: excluir todas las rotaciones excepto las 3 muestras en 0°
repo/casillas/*_90.html
repo/casillas/*_180.html
repo/casillas/*_270.html
repo/casillas/casilla_*.html
!repo/casillas/casilla_Colonia_Moderna_0.html
!repo/casillas/casilla_Plaza_del_Sol_0.html
!repo/casillas/casilla_Colapso_del_Per__frico_0.html

# Tarjetas: excluir todas excepto 3 muestras
repo/tarjetas/tarjeta_*.html
!repo/tarjetas/tarjeta_Colonia_Moderna.html
!repo/tarjetas/tarjeta_Telcel_Jalisco.html
!repo/tarjetas/tarjeta_Casa_de_Cambio_Centro.html

# Fortunas: excluir todas excepto 1 por carril
repo/fortunas/fortuna_*.html
!repo/fortunas/fortuna_1_Carta_de_Pistola.html
!repo/fortunas/fortuna_2_Dados_Cargados.html
!repo/fortunas/fortuna_3_Banca_Popular.html

